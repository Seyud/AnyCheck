    <!-- ksu_syscall -->
    <string name="chk_ksu_syscall_name">KernelSU 内核接口</string>
    <string name="chk_ksu_syscall_name_selinux">SELinux 宽容模式</string>
    <string name="chk_ksu_syscall_desc">检测到 KernelSU 内核接口。</string>
    <string name="chk_ksu_syscall_desc_nd">未发现 KernelSU 内核接口。</string>
    <string name="chk_ksu_syscall_desc_selinux">SELinux 处于宽容模式（潜在 KernelSU 指标）。</string>
    <string name="chk_ksu_syscall_reason">KernelSU 在 /sys/kernel/ksu 或 /proc/sys/kernel/ksu 公开内核接口。这确认 KernelSU 已编译到运行的内核中。发现：%1$s。</string>
    <string name="chk_ksu_syscall_reason_nd">未检测到 KernelSU 特定内核接口。</string>
    <string name="chk_ksu_syscall_reason_selinux">SELinux 强制状态为 0（宽容）。KernelSU 和其他 Root 解决方案通常将 SELinux 设置为宽容模式以允许无限制的 Root 访问。这会显著降低设备安全性。</string>
    <string name="chk_ksu_syscall_solution">刷入不含 KernelSU 的原厂内核以移除此接口。</string>
    <string name="chk_ksu_syscall_solution_selinux">将 SELinux 设置为强制模式：`setenforce 1`。此设置仅在重启前有效，除非 KernelSU/Magisk 策略覆盖它。</string>

