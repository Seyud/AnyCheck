    <!-- ksu_files -->
    <string name="chk_ksu_files_name">检测到 KernelSU 文件</string>
    <string name="chk_ksu_files_name_nd">KernelSU 文件</string>
    <string name="chk_ksu_files_desc">发现 KernelSU 特定文件或目录。</string>
    <string name="chk_ksu_files_desc_nd">未检测到 KernelSU 特定文件。</string>
    <string name="chk_ksu_files_reason">发现以下 KernelSU 文件：%1$s。KernelSU 是基于内核的 Root 解决方案。ksud 是 KernelSU 守护程序，/data/adb/ksu 是其工作目录。</string>
    <string name="chk_ksu_files_reason_nd">未在此设备上发现已知的 KernelSU 文件路径。</string>
    <string name="chk_ksu_files_solution">要移除 KernelSU：使用 KernelSU 管理器 → 卸载，或通过 fastboot 刷入非 KernelSU 内核/原厂 boot 镜像。</string>

    <!-- ksu_packages -->
    <string name="chk_ksu_packages_name">检测到 KernelSU 管理器</string>
    <string name="chk_ksu_packages_name_nd">KernelSU 管理器包</string>
    <string name="chk_ksu_packages_desc">已安装 KernelSU 管理器或相关应用。</string>
    <string name="chk_ksu_packages_desc_nd">未发现 KernelSU 管理器包。</string>
    <string name="chk_ksu_packages_reason">发现 KernelSU 包：%1$s。KernelSU 管理器应用是 KernelSU 的管理界面。其存在确认已安装 KernelSU。</string>
    <string name="chk_ksu_packages_reason_nd">未安装已知的 KernelSU 包名称。</string>
    <string name="chk_ksu_packages_solution">使用 KernelSU 管理器卸载，然后刷入原厂内核。</string>

    <!-- ksu_kernel_version -->
    <string name="chk_ksu_kernel_version_name">内核版本中包含 KernelSU</string>
    <string name="chk_ksu_kernel_version_name_nd">KernelSU 内核版本</string>
    <string name="chk_ksu_kernel_version_desc">在内核版本字符串中发现 KernelSU 签名。</string>
    <string name="chk_ksu_kernel_version_desc_nd">内核版本字符串中未发现 KernelSU 签名。</string>
    <string name="chk_ksu_kernel_version_desc_error">无法读取内核版本。</string>
    <string name="chk_ksu_kernel_version_reason">内核版本字符串包含 KernelSU 标记：%1$s。KernelSU 修补内核并将其版本嵌入内核字符串。内核：%2$s</string>
    <string name="chk_ksu_kernel_version_reason_nd">内核版本字符串不包含 KernelSU 标记。</string>
