    <string name="chk_ksu_processes_desc_error">无法枚举进程。</string>
    <string name="chk_ksu_processes_reason">发现进程：%1$s。ksud 是 KernelSU 用户空间守护程序，处理 su 请求。</string>
    <string name="chk_ksu_processes_reason_nd">未在运行进程列表中发现 KernelSU 进程名称。</string>
