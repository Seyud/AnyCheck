    <!-- ksu_syscall -->
    <string name="chk_ksu_syscall_name">KernelSU Kernel Interface</string>
    <string name="chk_ksu_syscall_name_selinux">SELinux Permissive Mode</string>
    <string name="chk_ksu_syscall_desc">KernelSU kernel interface detected.</string>
    <string name="chk_ksu_syscall_desc_nd">No KernelSU kernel interface found.</string>
    <string name="chk_ksu_syscall_desc_selinux">SELinux is in permissive mode (potential KernelSU indicator).</string>
    <string name="chk_ksu_syscall_reason">KernelSU exposes a kernel interface at /sys/kernel/ksu or /proc/sys/kernel/ksu. This confirms KernelSU is compiled into the running kernel. Found: %1$s.</string>
    <string name="chk_ksu_syscall_reason_nd">No KernelSU-specific kernel interfaces were detected.</string>
    <string name="chk_ksu_syscall_reason_selinux">SELinux enforce status is 0 (permissive). KernelSU and other root solutions often set SELinux to permissive mode to allow unrestricted root access. This significantly reduces device security.</string>
    <string name="chk_ksu_syscall_solution">Flash a stock kernel without KernelSU to remove this interface.</string>
    <string name="chk_ksu_syscall_solution_selinux">Set SELinux to enforcing mode: `setenforce 1`. This setting persists only until reboot unless KernelSU/Magisk policies override it.</string>

    <!-- ksu_props -->
    <string name="chk_ksu_props_name">KernelSU System Properties</string>
    <string name="chk_ksu_props_desc">KernelSU-specific system properties found.</string>
    <string name="chk_ksu_props_desc_nd">No KernelSU system properties found.</string>
    <string name="chk_ksu_props_reason">The following KernelSU properties were found: %1$s. These properties are set by KernelSU and confirm its presence.</string>
    <string name="chk_ksu_props_reason_nd">No KernelSU-specific system properties were detected.</string>
    <string name="chk_ksu_props_solution">These properties are removed when KernelSU is uninstalled.</string>
